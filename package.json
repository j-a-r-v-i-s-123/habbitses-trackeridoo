{
  "name": "habbitses-trackeridoo",
  "version": "1.0.0",
  "private": true,
  "description": "Habit Tracker application",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "typecheck": "tsc --noEmit",
    "test": "jest --forceExit --detectOpenHandles",
    "test:unit": "jest --testPathPatterns='unit' --forceExit",
    "test:integration": "jest --testPathPatterns='integration' --forceExit --detectOpenHandles"
  },
  "dependencies": {
    "@prisma/client": "^6.4.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.2",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.13.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.11",
    "@types/supertest": "^7.2.0",
    "jest": "^30.3.0",
    "prisma": "^6.4.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.7.3"
  }
}
